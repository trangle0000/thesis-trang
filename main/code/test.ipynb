   "id": "bf4d7b70",
   "metadata": {},
   "outputs": [],
   "source": [
    "x_1 = sp.Symbol('x_1')\n",
    "x_2 = sp.Symbol('x_2')\n",
    "alpha = sp.Symbol('alpha')\n",
    "Q = sp.Symbol('Q')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "id": "b764c87b",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/latex": [
       "$\\displaystyle x_{1}^{\\alpha} x_{2}^{1 - \\alpha}$"
      ],
      "text/plain": [
       "x_1**alpha*x_2**(1 - alpha)"
      ]
     },
     "execution_count": 11,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "f = x_1 ** alpha * x_2 ** (1-alpha)\n",
    "f"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 15,
   "id": "41438469",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/latex": [
