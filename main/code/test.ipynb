      ],
      "text/plain": [
       "alpha*x_1**(alpha - 1)*x_2**(1 - alpha)"
      ]
     },
     "execution_count": 15,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "sp.simplify(f.diff(x_1))"
